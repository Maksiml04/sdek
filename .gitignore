.env.*

# Logs and temporary files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/

# Build artifacts
dist/
build/
target/
*.so
*.dylib
*.dll
*.exe
*.out

# Coverage
.coverage
coverage/
htmlcov/

# Compression
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```